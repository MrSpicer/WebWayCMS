@page "/_spike/counter"
@rendermode InteractiveServer
@attribute [ExcludeFromCodeCoverage]
@*
    THROWAWAY Phase-0 verification artifact.

    Proves that blazor.web.js loads and an Interactive Server circuit hydrates inside
    the hybrid MVC + Blazor host (the riskiest unknown in the migration). If the count
    increments on click without a full page reload, the SignalR circuit is live.

    Remove this file once real interactive components exist (Phase 3), or sooner.
    Excluded from coverage because it is temporary scaffolding, not shipping logic.
*@
<PageTitle>Blazor SSR spike</PageTitle>

<h1>Blazor SSR hydration spike</h1>

<p>
    Current count: <span id="spike-count">@_currentCount</span>
</p>

<button id="spike-increment" type="button" @onclick="IncrementCount">Click me</button>

@code {
    private int _currentCount;

    private void IncrementCount() => _currentCount++;
}
