@namespace WebWayCMS.Presentation.Components
@inherits LayoutComponentBase
@attribute [ExcludeFromCodeCoverage]
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@*
    Admin document chrome for routable Blazor admin pages - the Blazor counterpart of
    _AdminLayout.cshtml. Contributes the admin stylesheets to <head> via HeadContent (the App
    root supplies the document + HeadOutlet). Logicless shell -> excluded from coverage.
    The CKEditor stylesheet + license-key meta support the RichTextEditor interop component; the
    CKEditor engine itself is imported on demand by richtext.js. The admin navbar (_AdminNavbar /
    Page nav) is added in a later sub-phase.
*@
<HeadContent>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ckeditor5@46.1.1/dist/ckeditor5.css" />
    <link rel="stylesheet" href="_content/WebWayCMS.Presentation/css/admin.css" />
    <meta name="ckeditor-license-key" content="@(Configuration["CKEditor:LicenseKey"] ?? string.Empty)" />
</HeadContent>

<div class="admin-shell">
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <header class="admin-header" role="banner">
        <WebWayCMS.Presentation.Components.Admin.AdminNavbar />
    </header>
    <main id="main-content" class="admin-main" tabindex="-1">
        @Body
    </main>
</div>
