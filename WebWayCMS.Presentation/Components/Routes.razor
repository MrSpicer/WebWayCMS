@namespace WebWayCMS.Presentation.Components
@attribute [ExcludeFromCodeCoverage]
@*
    Router for the Blazor-routed surface of the app: the interactive admin pages (/admin/*) and the
    Blazor Identity pages (/Account/*). MVC routing still owns the DB-driven public/admin page routes
    (rendered as Blazor via the page controllers), so this Router only resolves explicitly declared
    @page components in this assembly. Logicless shell -> excluded from coverage.
*@
<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <p>Not found.</p>
    </NotFound>
</Router>
