@namespace WebWayCMS.Presentation.Components.Layouts
@* Four equal columns (3/3/3/3). *@
<section class="section">
    <div class="container">
        <div class="columns">
            <div class="column is-3">
                <ContentZone ZoneName="Column1" />
            </div>
            <div class="column is-3">
                <ContentZone ZoneName="Column2" />
            </div>
            <div class="column is-3">
                <ContentZone ZoneName="Column3" />
            </div>
            <div class="column is-3">
                <ContentZone ZoneName="Column4" />
            </div>
        </div>
    </div>
</section>
