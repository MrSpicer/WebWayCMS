@namespace WebWayCMS.Presentation.Components.Account.Shared
@inherits LayoutComponentBase
@attribute [System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
@*
    Two-column document chrome for the Account/Manage pages: the manage nav sidebar plus the page
    body. Contributes the shared stylesheets. Logicless shell -> excluded from coverage.
*@
<HeadContent>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css" />
    <link rel="stylesheet" href="_content/WebWayCMS.Presentation/css/admin.css" />
</HeadContent>

<section class="section">
    <div class="container">
        <h1 class="title is-4">Manage your account</h1>
        <div class="columns">
            <div class="column is-one-quarter">
                <ManageNavMenu />
            </div>
            <div class="column">
                @Body
            </div>
        </div>
    </div>
</section>
