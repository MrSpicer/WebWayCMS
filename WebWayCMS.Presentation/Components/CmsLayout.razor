@namespace WebWayCMS.Presentation.Components
@using WebWayCMS.Presentation.Rendering
@inject ICmsChromeRegistry ChromeRegistry
@*
    Document shell for Blazor-rendered CMS pages - the Blazor equivalent of the library's
    minimal Views/Shared/_Layout.cshtml fallback. Emits the full HTML document, the
    HeadOutlet, the interactive runtime script, and injects per-page Meta/Style/Script.

    The CMS owns the document and framework script; a host brands the public site by providing a
    [CmsChrome] component (see CmsChromeBase). When present, the page body is wrapped in that chrome;
    otherwise it renders in the default <main> element.
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Title</title>
    @if (!string.IsNullOrWhiteSpace(Meta))
    {
        @((MarkupString)Meta!)
    }
    @if (!string.IsNullOrWhiteSpace(Style))
    {
        <style>@((MarkupString)Style!)</style>
    }
    <HeadOutlet />
</head>
<body>
    @if (_chromeType is not null)
    {
        <DynamicComponent Type="_chromeType" Parameters="_chromeParameters" />
    }
    else
    {
        <main role="main">
            @ChildContent
        </main>
    }
    @if (!string.IsNullOrWhiteSpace(Script))
    {
        <script>@((MarkupString)Script!)</script>
    }
    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Meta { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Script { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private Type? _chromeType;
    private IDictionary<string, object> _chromeParameters = new Dictionary<string, object>();

    protected override void OnParametersSet()
    {
        _chromeType = ChromeRegistry.ChromeType;
        // The host chrome receives the page body through its ChildContent parameter (CmsChromeBase).
        _chromeParameters = new Dictionary<string, object> { ["ChildContent"] = ChildContent! };
    }
}
