@namespace WebWayCMS.Presentation.Components.Admin
@using Microsoft.AspNetCore.Components.Authorization
@attribute [System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
@*
    Admin navigation bar for the Blazor admin layout (counterpart of _AdminNavbar.cshtml). Brand-area
    burger toggle (collapses the menu below 1024px via admin.js), the static section links, plus
    account/logout with icons. Logicless shell -> excluded from coverage.
    NOTE: the MVC navbar also rendered a dynamic admin-page nav (a DB-querying view component). Porting
    that as a navbar widget races the page's own query on the shared scoped DbContext (EF "second
    operation on this context"), so it is intentionally omitted here.
*@
<nav class="navbar admin-navbar" role="navigation" aria-label="Administration">
    <div class="navbar-brand">
        <button class="navbar-burger" aria-label="Toggle navigation menu" aria-expanded="false"
                aria-controls="adminNav" data-target="adminNav">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </button>
    </div>

    <div id="adminNav" class="navbar-menu">
        <div class="navbar-start">
            <NavLink class="navbar-item" href="/admin/site-pages">Pages</NavLink>
            <NavLink class="navbar-item" href="/admin/zones">Content Zones</NavLink>
            <NavLink class="navbar-item" href="/admin/blocks">Content Blocks</NavLink>
            <NavLink class="navbar-item" href="/admin/article-lists">Articles</NavLink>
        </div>
        <div class="navbar-end">
            <a class="navbar-item" href="/">View Site</a>
            <AuthorizeView>
                <Authorized>
                    <a class="navbar-item" href="/Account/Manage" aria-label="Manage account">
                        <span class="icon"><i class="fas fa-user-circle" aria-hidden="true"></i></span>
                        <span>@context.User.Identity?.Name</span>
                    </a>
                    <div class="navbar-item">
                        <form action="/Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="returnUrl" value="" />
                            <button type="submit" class="button is-small is-light">
                                <span class="icon"><i class="fas fa-sign-out-alt" aria-hidden="true"></i></span>
                                <span>Logout</span>
                            </button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="navbar-item" href="/Account/Login">Login</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>
