@namespace WebWayCMS.Presentation.Components.Admin
@using System.Text.Json
@using WebWayCMS.ContentZones
@using WebWayCMS.Forms
@using WebWayCMS.Presentation.Rendering
@inject IContentZoneComponentRegistry Registry
@inject IContentZoneViewRegistry ViewRegistry
@inject IFormOptionsProvider OptionsProvider
@*
    Add/Edit widget modal: pick a component (add mode) and edit its configuration via
    InteractiveFormFields, then raise OnSaved with the component name + serialized JSON.
    In edit mode the component is fixed and its existing JSON is deserialized into the form.
*@
<div class="modal is-active cz-item-form" role="dialog" aria-modal="true">
    <div class="modal-background" @onclick="OnCancel"></div>
    <div class="modal-card">
        <header class="modal-card-head">
            <h2 class="modal-card-title">@(IsEdit ? "Edit Widget" : "Add Widget")</h2>
            <button class="delete close-form" aria-label="Close dialog" @onclick="OnCancel"></button>
        </header>
        <section class="modal-card-body">
            <div class="field">
                <label class="label">Component</label>
                <div class="control">
                    <div class="select is-fullwidth">
                        <select class="component-selector" disabled="@IsEdit" @onchange="OnComponentChanged">
                            <option value="">-- Select a component --</option>
                            @foreach (var category in _byCategory)
                            {
                                <optgroup label="@category.Key">
                                    @foreach (var c in category.Value)
                                    {
                                        <option value="@c.Name" selected="@(c.Name == _componentName)">@c.DisplayName</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                </div>
            </div>

            @if (_availableViews.Count > 0)
            {
                <div class="field">
                    <label class="label">View</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select class="view-selector" @onchange="OnViewChanged">
                                <option value="" selected="@(string.IsNullOrEmpty(_viewName))">-- Default --</option>
                                @foreach (var v in _availableViews)
                                {
                                    <option value="@v" selected="@(v == _viewName)">@v</option>
                                }
                            </select>
                        </div>
                    </div>
                    <p class="help">The view template to render this component with. Leave empty for the default.</p>
                </div>
            }

            @if (_config is not null && _properties.Count > 0)
            {
                <hr />
                <InteractiveFormFields Model="_config" Properties="_properties" Options="_options" />
            }
        </section>
        <footer class="modal-card-foot">
            <button class="button is-success save-form" disabled="@(_componentName is null)" @onclick="SaveAsync">Save</button>
            <button class="button cancel-form" @onclick="OnCancel">Cancel</button>
        </footer>
    </div>
</div>

@code {
    [Parameter] public string? EditComponentName { get; set; }
    [Parameter] public string? EditViewName { get; set; }
    [Parameter] public string? EditJson { get; set; }
    [Parameter] public EventCallback<ContentZoneItemFormResult> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private IReadOnlyDictionary<string, IReadOnlyList<ContentZoneComponentInfo>> _byCategory =
        new Dictionary<string, IReadOnlyList<ContentZoneComponentInfo>>();
    private string? _componentName;
    private string? _viewName;
    private IReadOnlyList<string> _availableViews = Array.Empty<string>();
    private object? _config;
    private IReadOnlyList<FormPropertyInfo> _properties = Array.Empty<FormPropertyInfo>();
    private Dictionary<string, IReadOnlyList<FormOption>> _options = new();

    private bool IsEdit => EditComponentName is not null;

    protected override async Task OnInitializedAsync()
    {
        _byCategory = Registry.GetComponentsByCategory();
        if (EditComponentName is not null)
            await LoadComponentAsync(EditComponentName, EditJson, EditViewName);
    }

    private async Task OnComponentChanged(ChangeEventArgs e) => await LoadComponentAsync(e.Value as string, null);

    private void OnViewChanged(ChangeEventArgs e)
    {
        var value = e.Value as string;
        _viewName = string.IsNullOrEmpty(value) ? null : value;
    }

    private async Task LoadComponentAsync(string? name, string? json, string? viewName = null)
    {
        _componentName = string.IsNullOrEmpty(name) ? null : name;
        _viewName = null;
        _availableViews = Array.Empty<string>();
        _config = null;
        _properties = Array.Empty<FormPropertyInfo>();
        _options = new();
        if (_componentName is null)
            return;

        var info = Registry.GetByName(_componentName);
        if (info is null)
            return;

        _availableViews = ViewRegistry.GetComponentViews(_componentName);
        _viewName = viewName;
        _config = Deserialize(json, info.ConfigurationType) ?? Registry.CreateDefaultConfiguration(_componentName);
        _properties = info.Properties;

        foreach (var prop in _properties)
        {
            var options = await OptionsProvider.GetOptionsAsync(prop);
            if (options.Count > 0)
                _options[prop.Name] = options;
        }
    }

    private static object? Deserialize(string? json, Type? type)
    {
        if (type is null || string.IsNullOrEmpty(json) || json == "{}")
            return null;
        return JsonSerializer.Deserialize(json, type, JsonOpts);
    }

    private async Task SaveAsync()
    {
        if (_componentName is null)
            return;
        var json = _config is null ? "{}" : JsonSerializer.Serialize(_config, _config.GetType(), JsonOpts);
        await OnSaved.InvokeAsync(new ContentZoneItemFormResult(_componentName, _viewName ?? string.Empty, json));
    }

    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };
}
