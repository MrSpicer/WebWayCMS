@page "/admin/zones/create"
@page "/admin/zones/edit/{Id:guid}"
@namespace WebWayCMS.Presentation.Components.Admin
@using Microsoft.AspNetCore.Authorization
@using WebWayCMS.Presentation.Components
@attribute [Authorize(Roles = "Admin")]
@attribute [System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
@layout AdminLayout
@rendermode InteractiveServer
@*
    Routable Interactive Server wrapper for the content-zone metadata create/edit form. Logicless
    shell: binds the optional {Id} route value and delegates to the generic AdminUpsert. Zone *items*
    are managed separately via the interactive zone editor (/admin/zone-editor/{id}).
*@
<PageTitle>Content Zone</PageTitle>

<AdminUpsert ContentType="contentzones" Id="Id" ListUrl="/admin/zones" />

@code {
    [Parameter] public Guid? Id { get; set; }
}
