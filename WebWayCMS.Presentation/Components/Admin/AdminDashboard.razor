@namespace WebWayCMS.Presentation.Components.Admin
@using WebWayCMS.Data.Models
@using WebWayCMS.Data.Services
@inject IPageService PageService
@inject IContentService<ArticleDTO> ArticleService
@inject IContentService<ContentBlockDTO> ContentBlockService
@inject IContentZoneService ContentZoneService
@*
    Admin dashboard (stats + recent content + quick actions), the Blazor counterpart of the MVC
    GenericAdminPage/Dashboard.cshtml. Read-only; rendered Static SSR inside AdminPageHost.
*@
<section class="section">
    <div class="container">
        <div class="level mb-5">
            <div class="level-left">
                <div>
                    <h1 class="title">Dashboard</h1>
                    <p class="subtitle">Welcome to the CMS!</p>
                </div>
            </div>
            <div class="level-right">
                <a href="/" target="_blank" rel="noopener" class="button is-light">
                    <span class="icon"><i class="fas fa-external-link-alt"></i></span>
                    <span>View Site</span>
                </a>
            </div>
        </div>

        <div class="columns mb-5">
            <div class="column">
                <div class="box">
                    <p class="heading">Pages</p>
                    <p class="title">@_totalPages</p>
                    <div class="tags mt-2">
                        <span class="tag is-success">@_publishedPages published</span>
                        <span class="tag is-warning">@_draftPages draft</span>
                    </div>
                </div>
            </div>
            <div class="column">
                <div class="box">
                    <p class="heading">Articles</p>
                    <p class="title">@_totalArticles</p>
                </div>
            </div>
            <div class="column">
                <div class="box">
                    <p class="heading">Content Blocks</p>
                    <p class="title">@_totalBlocks</p>
                </div>
            </div>
            <div class="column">
                <div class="box">
                    <p class="heading">Content Zones</p>
                    <p class="title">@_totalZones</p>
                </div>
            </div>
        </div>

        <div class="columns mb-5">
            <div class="column is-8">
                <div class="card">
                    <div class="card-header"><p class="card-header-title">Recent Pages</p></div>
                    <div class="card-content p-0">
                        @if (_recentPages.Count == 0)
                        {
                            <div class="notification is-info m-4">
                                No pages yet. <a href="/admin/site-pages/create">Create your first page</a>.
                            </div>
                        }
                        else
                        {
                            <div class="table-container">
                                <table class="table is-fullwidth is-striped">
                                    <thead>
                                        <tr><th>Title</th><th>Route</th><th>Status</th><th>Modified</th><th></th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in _recentPages)
                                        {
                                            <tr>
                                                <td>@p.ContentMeta.Title</td>
                                                <td><code>@p.Route</code></td>
                                                <td>
                                                    @if (p.ContentMeta.IsPublished)
                                                    {
                                                        <span class="tag is-success">Published</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="tag is-warning">Draft</span>
                                                    }
                                                </td>
                                                <td>@p.ContentMeta.ModificationDate.ToString("MMM d, yyyy")</td>
                                                <td>
                                                    <div class="buttons are-small">
                                                        <a href="@p.Route" target="_blank" rel="noopener" class="button is-info is-light">View</a>
                                                        <a href="/admin/site-pages/edit/@p.ContentMeta.Id" class="button is-light">Edit</a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        <a href="/admin/site-pages" class="card-footer-item">View all pages</a>
                    </div>
                </div>
            </div>

            <div class="column is-4">
                <div class="card">
                    <div class="card-header"><p class="card-header-title">Quick Actions</p></div>
                    <div class="card-content">
                        <aside class="menu">
                            <p class="menu-label">Create New</p>
                            <ul class="menu-list">
                                <li><a href="/admin/site-pages/create"><span class="icon-text"><span class="icon"><i class="fas fa-plus"></i></span><span>New Page</span></span></a></li>
                                <li><a href="/admin/blocks/create"><span class="icon-text"><span class="icon"><i class="fas fa-plus"></i></span><span>New Content Block</span></span></a></li>
                            </ul>
                            <p class="menu-label">Manage</p>
                            <ul class="menu-list">
                                <li><a href="/admin/site-pages"><span class="icon-text"><span class="icon"><i class="fas fa-file-alt"></i></span><span>Pages</span></span></a></li>
                                <li><a href="/admin/article-lists"><span class="icon-text"><span class="icon"><i class="fas fa-newspaper"></i></span><span>Articles</span></span></a></li>
                                <li><a href="/admin/blocks"><span class="icon-text"><span class="icon"><i class="fas fa-cubes"></i></span><span>Content Blocks</span></span></a></li>
                                <li><a href="/admin/zones"><span class="icon-text"><span class="icon"><i class="fas fa-layer-group"></i></span><span>Content Zones</span></span></a></li>
                            </ul>
                        </aside>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-5">
            <div class="card-header"><p class="card-header-title">Recent Articles</p></div>
            <div class="card-content p-0">
                @if (_recentArticles.Count == 0)
                {
                    <div class="notification is-info m-4">
                        No articles yet. <a href="/admin/article-lists">Manage articles</a>.
                    </div>
                }
                else
                {
                    <div class="table-container">
                        <table class="table is-fullwidth is-striped">
                            <thead>
                                <tr><th>Title</th><th>Author</th><th>Status</th><th>Modified</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var article in _recentArticles)
                                {
                                    <tr>
                                        <td>@article.ContentMeta.Title</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(article.AuthorName))
                                            {
                                                <span class="has-text-grey-light is-italic">—</span>
                                            }
                                            else
                                            {
                                                <span class="icon-text"><span class="icon"><i class="fas fa-user"></i></span><span>@article.AuthorName</span></span>
                                            }
                                        </td>
                                        <td>
                                            @if (article.ContentMeta.IsPublished)
                                            {
                                                <span class="tag is-success">Published</span>
                                            }
                                            else
                                            {
                                                <span class="tag is-warning">Draft</span>
                                            }
                                        </td>
                                        <td>@article.ContentMeta.ModificationDate.ToString("MMM d, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="card-footer">
                <a href="/admin/article-lists" class="card-footer-item">View all articles</a>
            </div>
        </div>
    </div>
</section>

@*
    Render the page's "Main" content zone only once the dashboard's own queries have completed: during
    the initial (pre-data) SSR render the zone's DB query would otherwise run concurrently with these
    queries on the same scoped DbContext ("a second operation was started on this context instance").
*@
@if (_loaded)
{
    <ContentZone ZoneName="Main" />
}

@code {
    private int _totalPages, _publishedPages, _draftPages, _totalArticles, _totalBlocks, _totalZones;
    private List<PageDTO> _recentPages = new();
    private List<ArticleDTO> _recentArticles = new();
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        var allPages = await PageService.GetAllAsync();
        var allArticles = await ArticleService.GetAllAsync();
        var allBlocks = await ContentBlockService.GetAllAsync();
        var allZones = await ContentZoneService.GetAllAsync();

        _totalPages = allPages.Count;
        _publishedPages = allPages.Count(p => p.ContentMeta.IsPublished);
        _draftPages = allPages.Count(p => !p.ContentMeta.IsPublished);
        _totalArticles = allArticles.Count;
        _totalBlocks = allBlocks.Count;
        _totalZones = allZones.Count;

        _recentPages = allPages.OrderByDescending(p => p.ContentMeta.ModificationDate).Take(8).ToList();
        _recentArticles = allArticles.OrderByDescending(a => a.ContentMeta.ModificationDate).Take(5).ToList();

        _loaded = true;
    }
}
