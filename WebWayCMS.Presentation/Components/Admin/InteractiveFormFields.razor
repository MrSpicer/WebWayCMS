@namespace WebWayCMS.Presentation.Components.Admin
@using WebWayCMS.Attributes
@using WebWayCMS.Forms
@using WebWayCMS.Presentation.Rendering
@*
    Interactive, metadata-driven form. Each field reads/writes the bound Model's property by
    reflection (via FormValueConverter), so editing updates the model in place ready for save or JSON
    serialization. Covers the editor types used by both content-zone component configs and the admin
    content view models (Hidden/Text/TextArea/DateTime/Date/Number/Url/Email/Color/Checkbox/Dropdown
    + entity/view pickers via Options, grouped under their FormProperty Group). RichText renders the
    CKEditor-backed RichTextEditor component via JS interop.
*@
@{
    string? currentGroup = null;
}
@foreach (var prop in Properties)
{
    if (!string.IsNullOrEmpty(prop.Group) && prop.Group != currentGroup)
    {
        currentGroup = prop.Group;
        <h3 class="subtitle is-5 mt-4">@prop.Group</h3>
    }

    if (prop.EditorType == EditorType.Hidden)
    {
        <input type="hidden" data-prop="@prop.Name" value="@Display(prop)" @onchange="e => Set(prop, e)" />
    }
    else if (prop.EditorType == EditorType.Checkbox)
    {
        <div class="field">
            <label class="checkbox">
                <input type="checkbox" data-prop="@prop.Name" checked="@IsChecked(prop)" @onchange="e => SetBool(prop, e)" />
                @prop.Label
                @if (prop.IsRequired)
                {
                    <span class="has-text-danger">*</span>
                }
            </label>
        </div>
    }
    else
    {
        <div class="field">
            <label class="label">
                @prop.Label
                @if (prop.IsRequired)
                {
                    <span class="has-text-danger">*</span>
                }
            </label>
            <div class="control">
                @if (TryOptions(prop, out var pickerOptions))
                {
                    <div class="select is-fullwidth">
                        <select data-prop="@prop.Name" @onchange="e => Set(prop, e)">
                            <option value="">-- Select --</option>
                            @foreach (var o in pickerOptions)
                            {
                                <option value="@o.Value" selected="@(o.Value == Display(prop))">@o.Label</option>
                            }
                        </select>
                    </div>
                }
                else if (prop.EditorType == EditorType.TextArea)
                {
                    <textarea class="textarea" data-prop="@prop.Name" @onchange="e => Set(prop, e)">@Display(prop)</textarea>
                }
                else if (prop.EditorType == EditorType.RichText)
                {
                    <RichTextEditor Value="@Display(prop)" ValueChanged="@(html => SetString(prop, html))" />
                }
                else if (prop.EditorType == EditorType.Dropdown)
                {
                    <div class="select is-fullwidth">
                        <select data-prop="@prop.Name" @onchange="e => Set(prop, e)">
                            <option value="">-- Select --</option>
                            @foreach (var opt in prop.DropdownOptions)
                            {
                                <option value="@opt.Key" selected="@(opt.Key == Display(prop))">@opt.Value</option>
                            }
                        </select>
                    </div>
                }
                else
                {
                    <input class="input" type="@InputType(prop.EditorType)" data-prop="@prop.Name" value="@Display(prop)" placeholder="@prop.Placeholder" @onchange="e => Set(prop, e)" />
                }
            </div>
            @if (!string.IsNullOrEmpty(prop.HelpText))
            {
                <p class="help">@prop.HelpText</p>
            }
        </div>
    }
}

@code {
    [Parameter, EditorRequired] public object Model { get; set; } = default!;

    [Parameter, EditorRequired] public IReadOnlyList<FormPropertyInfo> Properties { get; set; } = Array.Empty<FormPropertyInfo>();

    /// <summary>Per-field selectable options (keyed by property name) for picker fields; absent fields render plain inputs.</summary>
    [Parameter] public IReadOnlyDictionary<string, IReadOnlyList<FormOption>>? Options { get; set; }

    private bool TryOptions(FormPropertyInfo prop, out IReadOnlyList<FormOption> options)
    {
        if (Options is not null && Options.TryGetValue(prop.Name, out var found))
        {
            options = found;
            return true;
        }
        options = Array.Empty<FormOption>();
        return false;
    }

    // Maps an editor type to the corresponding HTML text-input type, mirroring the MVC tag-helper.
    private static string InputType(EditorType editorType) => editorType switch
    {
        EditorType.DateTime => "datetime-local",
        EditorType.Date => "date",
        EditorType.Number => "number",
        EditorType.Url => "url",
        EditorType.Email => "email",
        EditorType.Color => "color",
        _ => "text",
    };

    private System.Reflection.PropertyInfo? Pi(FormPropertyInfo prop) => Model.GetType().GetProperty(prop.Name);

    private string Display(FormPropertyInfo prop) => FormValueConverter.ToInput(Pi(prop)?.GetValue(Model), prop.EditorType);

    private bool IsChecked(FormPropertyInfo prop) => Pi(prop)?.GetValue(Model) is true;

    private void Set(FormPropertyInfo prop, ChangeEventArgs e)
    {
        var pi = Pi(prop);
        if (pi is not null)
            pi.SetValue(Model, FormValueConverter.FromInput(e.Value as string, pi.PropertyType));
    }

    private void SetBool(FormPropertyInfo prop, ChangeEventArgs e)
    {
        // A checkbox change event always provides the checked state as a bool.
        var pi = Pi(prop);
        if (pi is not null)
            pi.SetValue(Model, (bool)e.Value!);
    }

    // Writes a rich-text editor's HTML straight to the bound string property (no input event).
    private void SetString(FormPropertyInfo prop, string html)
    {
        var pi = Pi(prop);
        if (pi is not null)
            pi.SetValue(Model, html);
    }
}
