<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Local folder feed for dev iteration: `dotnet pack -o ./local-nuget` -->
    <add key="local-nuget" value="./local-nuget" />
    <!-- GitHub Packages feed for real distribution (requires GITHUB_TOKEN). -->
    <add key="github" value="https://nuget.pkg.github.com/MrSpicer/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github>
      <add key="Username" value="MrSpicer" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github>
  </packageSourceCredentials>
</configuration>
